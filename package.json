{
  "name": "daybreak-browser",
  "version": "1.0.0",
  "description": "A Chrome-style desktop browser built with Electron by WhiteDragon-303 (Daybreak)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:no-admin": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win portable"
  },
  "author": "WhiteDragon-303 (Daybreak)",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.daybreak.browser",
    "productName": "Daybreak Browser",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico",
      "sign": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Daybreak Browser"
    },
    "portable": {
      "artifactName": "DaybreakBrowser_Portable_${version}.exe"
    }
  }
}